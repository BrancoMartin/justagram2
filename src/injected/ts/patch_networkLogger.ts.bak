
(function() {
  const originalFetch = window.fetch;
  const originalXHROpen = window.XMLHttpRequest.prototype.open;

  // Filter out static assets to reduce noise
  const IGNORE_EXTENSIONS = ['.jpg', '.jpeg', '.png', '.gif', '.css', '.js', '.woff', '.woff2'];

  function shouldLog(url: string): boolean {
    if (!url) return false;
    // Check extension
    const cleanUrl = url.split('?')[0].toLowerCase();
    if (IGNORE_EXTENSIONS.some(ext => cleanUrl.endsWith(ext))) return false;
    
    // Ignore logging/telemetry endpoints to focus on content
    if (url.includes('logging_client_events') || url.includes('falco')) return false;

    return true;
  }

  // Patch fetch
  window.fetch = async function (input: RequestInfo | URL, init?: RequestInit): Promise<Response> {
    let url = '';
    let method = 'GET'; // Default

    if (typeof input === 'string') {
      url = input;
    } else if (input instanceof URL) {
      url = input.toString();
    } else if (input instanceof Request) {
      url = input.url;
      method = input.method;
    }

    if (init && init.method) {
      method = init.method;
    }

    if (shouldLog(url)) {
      console.log(`[JustAgram] 📡 FETCH [${method}]:`, url);
    }

    return originalFetch.apply(this, arguments as any);
  };

  // Patch XHR
  window.XMLHttpRequest.prototype.open = function (method: string, url: string | URL) {
    const urlStr = url.toString();
    if (shouldLog(urlStr)) {
      console.log(`[JustAgram] 📡 XHR [${method}]:`, urlStr);
    }
    return originalXHROpen.apply(this, arguments as any);
  };

  console.log('[JustAgram] 🔍 Network Logger Active');
})();
